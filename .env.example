# OpenRouter (required for @Pulse AI replies)
# Get a key at https://openrouter.ai/keys
# Default model: openrouter/free — https://openrouter.ai/openrouter/free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Slack (set by `slack run` or copy from app settings)
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=

# Neon PostgreSQL (pooled connection string)
DATABASE_URL=

# Optional: OAuth mode (app-oauth.js)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SLACK_REDIRECT_URI=

# Optional: protect cron/worker routes (Phase 5+)
# CRON_SECRET=your-random-secret
# PULSE_PEOPLE_OPS_CHANNEL_ID=C...   # optional if #people-ops lookup fails
# PULSE_ALERT_STARTUP_DELAY_MS=30000 # first proactive check after slack run (default 30s)
# PULSE_ALERT_INTERVAL_MS=300000     # repeat every 5 min (default)
# PULSE_WORKER_PORT=3200

# Pulse MCP server (local dev — start with npm run mcp:start)
PULSE_MCP_URL=http://localhost:3100/mcp
# PULSE_MCP_PORT=3100
