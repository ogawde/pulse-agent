# Production env — /opt/pulse/.env on droplet
# cp deploy/.env.production.example /opt/pulse/.env

NODE_ENV=production

# Slack — api.slack.com → Pulse app → OAuth & Permissions / App-Level Token
# Do NOT use slack run on the server; paste tokens here once.
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Neon pooled URL (same as local .env)
DATABASE_URL=postgresql://...

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Public MCP (Caddy api.pulse.curr.xyz → 127.0.0.1:3100)
PULSE_MCP_URL=https://api.pulse.curr.xyz/mcp
PULSE_MCP_PORT=3100

# pulsesandbox #people-ops
PULSE_PEOPLE_OPS_CHANNEL_ID=C0BE506430A

PULSE_ALERT_STARTUP_DELAY_MS=30000
PULSE_ALERT_INTERVAL_MS=300000
